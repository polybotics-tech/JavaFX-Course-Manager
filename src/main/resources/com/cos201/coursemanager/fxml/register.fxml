<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="540.0" prefWidth="480.0" spacing="48.0" stylesheets="@../css/auth.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cos201.coursemanager.controllers.LoginController">
   <children>
      <VBox maxWidth="1.7976931348623157E308" styleClass="heading">
         <children>
            <Label alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="title" text="Create New Account" textAlignment="CENTER" VBox.vgrow="ALWAYS" />
            <Label alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="subtitle" text="Welcome to Course Manager. Register to use app." textAlignment="CENTER" VBox.vgrow="ALWAYS" />
         </children>
      </VBox>
      <VBox prefHeight="200.0" prefWidth="100.0" spacing="16.0">
         <children>
            <VBox maxWidth="1.7976931348623157E308" styleClass="inp-group">
               <children>
                  <Label styleClass="inp-label" text="Your Fullname" />
                  <TextField fx:id="fullnameField" maxWidth="1.7976931348623157E308" prefHeight="48.0" promptText="ex. Onyeleonu Ifeanyichukwu" styleClass="inp-box" />
               </children>
            </VBox>
            <VBox maxWidth="1.7976931348623157E308" styleClass="inp-group">
               <children>
                  <Label styleClass="inp-label" text="Username" />
                  <TextField fx:id="usernameField" maxWidth="1.7976931348623157E308" prefHeight="48.0" promptText="ex. miva_4_life" styleClass="inp-box" />
               </children>
            </VBox>
            <VBox maxWidth="1.7976931348623157E308" styleClass="inp-group">
               <children>
                  <Label styleClass="inp-label" text="New Password" />
                  <PasswordField fx:id="passwordField" maxWidth="1.7976931348623157E308" prefHeight="48.0" promptText="Enter a password you can remember" styleClass="inp-box" />
               </children>
            </VBox>
         </children>
      </VBox>
      <VBox maxWidth="1.7976931348623157E308" styleClass="inp-group">
         <children>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleRegisterButtonAction" prefHeight="44.0" styleClass="submit-button" text="Register" />
            <HBox alignment="CENTER" maxWidth="1.7976931348623157E308" spacing="4.0">
               <children>
                  <Label styleClass="subtitle" text="Already have an existing account?" />
                  <Button mnemonicParsing="false" onAction="#handleSwitchToLoginScreenAction" styleClass="subtitle-link" text="Login" underline="true" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="24.0" left="32.0" right="32.0" top="24.0" />
   </padding>
</VBox>
