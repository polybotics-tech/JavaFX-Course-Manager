<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="540.0" prefWidth="480.0" spacing="48.0" stylesheets="@../css/auth.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cos201.coursemanager.controllers.LoginController">
    <children>
        <VBox maxWidth="1.7976931348623157E308" styleClass="heading">
            <children>
                <Label alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="title" text="Login To Your Account" textAlignment="CENTER" VBox.vgrow="ALWAYS" />
                <Label alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="subtitle" text="Welcome to Course Manager. A Miva COS201 Lab Project." textAlignment="CENTER" VBox.vgrow="ALWAYS" />
            </children>
        </VBox>
        <VBox maxWidth="1.7976931348623157E308" spacing="16.0">
            <children>
                <VBox maxWidth="1.7976931348623157E308" styleClass="inp-group">
                    <children>
                        <Label styleClass="inp-label" text="Username" />
                        <TextField fx:id="usernameField" maxWidth="1.7976931348623157E308" prefHeight="48.0" promptText="ex. miva_4_life" styleClass="inp-box" />
                    </children>
                </VBox>
                <VBox maxWidth="1.7976931348623157E308" styleClass="inp-group">
                    <children>
                        <Label styleClass="inp-label" text="Password" />
                        <PasswordField fx:id="passwordField" maxWidth="1.7976931348623157E308" prefHeight="48.0" promptText="Enter your account password" styleClass="inp-box" />
                    </children>
                </VBox>
            </children>
        </VBox>
        <VBox maxWidth="1.7976931348623157E308" styleClass="inp-group">
            <children>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLoginButtonAction" prefHeight="44.0" styleClass="submit-button" text="Continue to Dashboard" />
                <HBox alignment="CENTER" maxWidth="1.7976931348623157E308" spacing="4.0">
                    <children>
                        <Label styleClass="subtitle" text="Don't have an account?" />
                        <Button mnemonicParsing="false" onAction="#handleSwitchToRegisterScreenAction" styleClass="subtitle-link" text="Register" underline="true" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
    <padding>
        <Insets bottom="24.0" left="32.0" right="32.0" top="24.0" />
    </padding>
</VBox>
